# Copy this file to `.env` and edit values as needed:
#   cp .env.example .env
# Docker Compose loads `.env` automatically.
#
# ============================================================================
# !! SECURITY WARNING !!
# The default passwords below (`atakatak`) are the well-known ATAK defaults.
# They are fine for local, throwaway testing on a trusted machine ONLY.
# CHANGE every password marked "CHANGE ME" before exposing this server to
# any network you do not fully control. Strong values: 16+ characters, mixed
# case, digits, and symbols. Never commit your real `.env` to git.
# ============================================================================

# ---------------------------------------------------------------------------
# TAK release
# ---------------------------------------------------------------------------
# Version string must match the release zip you dropped at the repo root, e.g.
# `takserver-docker-5.7-RELEASE-43.zip` -> TAK_VERSION=5.7-RELEASE-43
TAK_VERSION=5.7-RELEASE-43

# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------
POSTGRES_DB=cot
POSTGRES_USER=martiuser
# CHANGE ME before exposing the server to anything you care about.
POSTGRES_PASSWORD=atakatak    # CHANGE ME

# ---------------------------------------------------------------------------
# TLS / certificates
# ---------------------------------------------------------------------------
# Password used for every generated .p12 (CA truststore + server + clients).
# CHANGE ME for any non-throwaway deployment. ATAK historically defaults to
# `atakatak`, which is convenient but obviously not secret.
TAK_CERT_PASSWORD=atakatak    # CHANGE ME

CA_NAME=TAK-Root-CA

# Comma-separated list of hostnames / IPs the server should be reachable on.
# The first entry becomes the certificate CN; every entry is added as a SAN,
# so clients can connect to any of them with the same server cert.
SERVER_HOSTNAMES=takserver,localhost,192.168.1.1

# Comma-separated list of client usernames to provision on first boot.
# Each gets a client .p12 and a Data Package (`<user>-<host>.dp.zip`) under
# data/certs/. Add/remove names and restart the stack to regenerate.
CLIENT_NAMES=client

# Cert identity fields (used by TAK's makeCert.sh / makeRootCa.sh).
COUNTRY=NL
STATE=XXXX
CITY=XXXX
ORGANIZATION=XXXX
ORGANIZATIONAL_UNIT=XXXX